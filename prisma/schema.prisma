// ============================================================
// Prisma Schema for a Doctor–Patient Appointment System
// Database: PostgreSQL
// ORM: Prisma Client (JavaScript/TypeScript)
// ============================================================

// Prisma Client Generator
// Generates a type-safe database client for querying your data
generator client {
  provider = "prisma-client-js"
}

// Database connection configuration
// Uses PostgreSQL via DATABASE_URL from the .env file
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER MODEL
// Represents patients or platform users authenticated via Clerk
// ============================================================
model User {
  id        String   @id @default(cuid())   // Unique ID generated by Prisma (Collision-resistant)
  clerkId   String   @unique                // Maps to the user's ID in Clerk (auth provider)
  email     String   @unique                // Unique email address
  firstName String?                         // Optional first name
  lastName  String?                         // Optional last name
  phone     String?                         // Optional phone number
  createdAt DateTime @default(now())        // Timestamp for when user was created
  updatedAt DateTime @updatedAt             // Auto-updates whenever record changes

  // Relationships
  appointments Appointment[]                // A user can have multiple appointments

  @@map("users")                            // Maps to the "users" table in PostgreSQL
}

// ============================================================
// DOCTOR MODEL
// Stores information about doctors registered on the platform
// ============================================================
model Doctor {
  id          String   @id @default(cuid()) // Unique doctor ID
  name        String                            // Doctor's full name
  email       String   @unique                  // Unique email for login/communication
  phone       String                            // Contact number
  speciality  String                            // Doctor's specialization (e.g., Orthodontist)
  bio         String?                           // Optional short biography or description
  imageUrl    String                            // Profile picture URL
  gender      Gender                            // Enum: MALE or FEMALE
  isActive    Boolean  @default(true)           // Active status, useful for soft disabling
  createdAt   DateTime @default(now())          // Creation timestamp
  updatedAt   DateTime @updatedAt               // Auto-updates when modified

  // Relationships
  appointments Appointment[]                    // A doctor can have multiple appointments

  @@map("doctors")                              // Maps to the "doctors" table
}

// ============================================================
// APPOINTMENT MODEL
// Represents a scheduled meeting between a User and a Doctor
// ============================================================
model Appointment {
  id          String            @id @default(cuid())       // Unique appointment ID
  date        DateTime                                     // Date of the appointment
  time        String                                      // Time stored as string (e.g., "14:30")
  duration    Int               @default(30)               // Duration in minutes (default: 30)
  status      AppointmentStatus @default(CONFIRMED)        // Enum: CONFIRMED or COMPLETED
  notes       String?                                     // Internal notes about the appointment
  reason      String?                                     // Patient's reason (e.g., Cleaning, Emergency)
  createdAt   DateTime          @default(now())            // Created timestamp
  updatedAt   DateTime          @updatedAt                 // Auto-updates when modified

  // Foreign Keys
  userId   String                                         // References User.id
  doctorId String                                         // References Doctor.id

  // Relationships
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("appointments")                                   // Maps to the "appointments" table
}

// ============================================================
// ENUMS
// Used for controlled and consistent field values
// ============================================================

// Gender options for doctors (can extend later if needed)
enum Gender {
  MALE
  FEMALE
}

// Appointment status options
enum AppointmentStatus {
  CONFIRMED     // Appointment booked and confirmed
  COMPLETED     // Appointment completed successfully
}
